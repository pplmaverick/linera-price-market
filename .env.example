# Linera Wallet Configuration
# Path to your Linera wallet file
# Default on macOS: ~/Library/Application Support/linera/wallet.json
LINERA_WALLET=~/Library/Application Support/linera/wallet.json

# Linera Storage Backend
# Local RocksDB storage (default for development)
LINERA_STORAGE=rocksdb:~/Library/Application Support/linera/storage

# Conway Testnet Faucet
LINERA_FAUCET=https://faucet.testnet-conway.linera.net

# Local Node Service Port
LINERA_SERVICE_PORT=8080
